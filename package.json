{
  "name": "playwright-demo",
  "version": "1.0.0",
  "description": "Full Stack Playwright Automation Framework with Open Banking CDR, Contract Testing, Database Validation, Allure Reporting, and Enterprise QE Scenarios",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:cdr": "npx playwright test tests/api/cdr",
    "test:database": "npx playwright test tests/database",
    "test:data": "npx playwright test tests/data",
    "test:performance": "npx playwright test tests/performance",
    "test:enterprise": "npm run test:cdr && npm run test:database && npm run test:performance",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "allure-commandline": "^2.41.0",
    "allure-playwright": "^3.9.0"
  },
  "dependencies": {
    "@axe-core/playwright": "^4.11.3",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "chrome-launcher": "^1.2.1",
    "lighthouse": "^12.8.2",
    "mysql2": "^3.22.3",
    "node-fetch": "^3.3.2",
    "swagger-parser": "^10.0.3"
  }
}
